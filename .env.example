APP_HOST=0.0.0.0
APP_PORT=8090
LOG_LEVEL=INFO

# stub — локальный режим без реального запроса к DeepSeek/OpenRouter, удобно для проверки задания
# deepseek — реальный POST-запрос в OpenAI-compatible /chat/completions
LLM_MODE=stub
LLM_API_BASE_URL=https://api.deepseek.com
LLM_API_KEY=put_api_key_here
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30
SYSTEM_PROMPT_PATH=prompts/system_prompt.md

# Вакансии теперь хранятся в PostgreSQL.
# Для запуска приложения напрямую из VS Code и PostgreSQL в Docker оставь localhost.
VACANCY_STORAGE=postgres
DATABASE_URL=postgresql://hr_bot:hr_bot_password@localhost:5432/hr_screening
SEED_VACANCIES_ON_STARTUP=true
MIN_SCREENING_QUESTIONS=4

POSTGRES_DB=hr_screening
POSTGRES_USER=hr_bot
POSTGRES_PASSWORD=hr_bot_password
